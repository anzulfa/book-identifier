# Copy this file to .env and fill in real values before running.

# PostgreSQL — matches docker-compose defaults
DATABASE_URL=postgresql+asyncpg://bookuser:bookpass@postgres:5432/bookidentifier

# Redis — matches docker-compose defaults
REDIS_URL=redis://redis:6379

# JWT signing secret — use a long random string in production
JWT_SECRET=change-me-to-a-long-random-secret

# Stub admin credentials for /api/auth/token
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# External API keys
ANTHROPIC_API_KEY=sk-ant-...
RAPIDAPI_KEY=your-rapidapi-key-here
GOOGLE_BOOKS_API_KEY=your-google-books-api-key-here   # optional — works without it at lower quota

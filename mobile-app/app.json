{
  "expo": {
    "name": "mobile-app",
    "slug": "mobile-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "mobileapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.palfa.bookidentifier"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.palfa.bookidentifier",
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "googleWebClientId": "998910272906-v3etbja60qds1afvuss0vtej457tg53a.apps.googleusercontent.com",
      "googleIosClientId": "998910272906-br82oo0kidpnhglj3gcpcnji8cvq6nsv.apps.googleusercontent.com",
      "googleAndroidClientId": "998910272906-683f90d12ld1ro6hmqdhivsrts2rcttq.apps.googleusercontent.com",
      "router": {},
      "eas": {
        "projectId": "3055cfc8-7c0f-4c5b-b3dc-a8c33c0d2fa4"
      }
    }
  }
}
